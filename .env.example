# Telegram Bot Token from BotFather
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Telegram Channel ID to post deals to
# Add your bot as an admin to your channel and use its username (e.g., @my_deal_channel) or numeric ID
TELEGRAM_CHANNEL_ID="@your_channel_username"

# Gemini API Key from Google AI Studio
GEMINI_API_KEY="your_gemini_api_key_here"

# Your Affiliate tags
AMAZON_AFFILIATE_TAG="your_amazon_tag-21"
FLIPKART_AFFILIATE_ID="your_flipkart_id"
